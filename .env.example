# Copy to .env on the Synology before running docker compose.
#
# Canonical data root (DSM shared folder Data/App_Development):
#   /volume2/Data/App_Development/ra2-lan-party
# Everything for this project must live under that tree:
#   RA2Yuri_Game1/   DODI installer (Setup.exe + data1.doi)
#   assets-game1/    extracted DODI game + LAN overlays (install script output)
#   assets/          manual game copy + cnc-ddraw/wsock32 (or legacy active mount)
#   prefixes/        Wine prefixes per player
#   project/         this repo (compose, scripts, container/)
#   logs/            player logs + game-work
#   tls/             HTTPS certs for browser play

PROJECT_ROOT=/volume2/Data/App_Development/ra2-lan-party
DODI_INSTALLER_DIR=/volume2/Data/App_Development/ra2-lan-party/RA2Yuri_Game1
# Active game files mounted into containers (switch to assets-game1 after DODI install):
ASSETS_DIR=/volume2/Data/App_Development/ra2-lan-party/assets
# ASSETS_DIR=/volume2/Data/App_Development/ra2-lan-party/assets-game1
# Age of Empires II (1999) unpacked install — host path for compose bind mount (player-1):
AOE2_ASSETS_HOST=/volume2/Data/Games/2 Unpacked - Ready to Play/Age of Empires 2
# CD mounts for in-game disc checks: sh scripts/stage-aoe2-discs.sh (once on NAS)
AOE2_STAGING_HOST=/volume2/Data/Games/2 Unpacked - Ready to Play/Age of Empires 2/.disc-staging
# English menus: sh scripts/install-aoe2-english-language.sh /path/to/aoc_english.zip
# (Italian unpack uses LANGUAGE.DLL overlay from config/aoe2-language/)
SC_ASSETS_HOST=/volume2/Data/Games/2 Unpacked - Ready to Play/StarCraft
SC_DISC_HOST=/volume2/Data/Games/1 Packed - Compressed/StarCraft & Brood War
SC_STAGING_HOST=/volume2/Data/Games/2 Unpacked - Ready to Play/StarCraft/.disc-staging
# Unpack: sh scripts/launch-starcraft-setup.sh → finalize-starcraft-install.sh
# No-CD: sh scripts/apply-starcraft-nocd.sh (INSTALL.EXE → StarCraft.mpq + BroodWar.mpq)
# StarCraft stream + in-game render: 640x480 (games.json); RA2/AoE II use 1024x768.
# In-container game selection menu (CLI — no GUI). Both players share the same game catalog.
# Stream users never get a shell: selection is host-admin only via scripts/select-game.sh.
GAME_LAUNCHER_ENABLED=1
# Optional: auto-pick after N seconds when waiting at menu (0 = wait forever):
# GAME_MENU_TIMEOUT=120
# GAME_MENU_DEFAULT=ra2
PREFIX1_DIR=/volume2/Data/App_Development/ra2-lan-party/prefixes/player1-win32
PREFIX2_DIR=/volume2/Data/App_Development/ra2-lan-party/prefixes/player2-win32
LOGS_DIR=/volume2/Data/App_Development/ra2-lan-party/logs

# RAM debug player (scripts/dev-ram-ultra.sh): full in-RAM on 12 GB+ hosts (18 GB NAS).
# Mirrors project + TLS + prefix + assets to /dev/shm; container tmpfs for logs/tmp/helper.
# After sync-to-nas from Mac: NAS_HOST=MediaServer2 sh scripts/dev-ram-ultra.sh refresh
DEV_RAM_HTTP_PORT=6091
# DEV_RAM_FULL=1           # default on 12 GB+ hosts
# DEV_RAM_MEM_LIMIT=5120m
# DEV_RAM_SHM_SIZE=2048m
# DEV_RAM_TMPFS_LOGS=1536m
# DEV_RAM_TMPFS_TMP=2048m
# RAM_PROJECT_DIR / RAM_PREFIX_DIR / RAM_ASSETS_DIR / RAM_TLS_DIR set by dev-ram-ultra.sh

TZ=America/New_York
RESOLUTION=1024x768
GAME_EXE=RA2MD.exe

# Conservative launch defaults for DSM. Leave restart disabled until the stack
# has passed verification; then set RA2_RESTART_POLICY=unless-stopped if desired.
RA2_RESTART_POLICY=no
RA2_PIDS_LIMIT=256

# Memory profile. Use two-player-low on stock 1.7 GB DS225+; with 18 GB RAM use default
# limits or raise RA2_MEM_LIMIT (e.g. 2048m per player) and RA2_SHM_SIZE=512m.
RA2_MEMORY_PROFILE=two-player-low
RA2_PRODUCTION_RAM_MIB=6144
RA2_MEM_LIMIT=512m
RA2_SHM_SIZE=256m
# 18 GB NAS example (after verification):
# RA2_MEMORY_PROFILE=default
# RA2_MEM_LIMIT=2048m
# RA2_SHM_SIZE=512m
# Ultra golden master: noVNC disabled in container (archived path only).
RA2_ENABLE_NOVNC_FALLBACK=0
RA2_ENABLE_AUDIO_PROXY=0
RA2_ENABLE_LATENCY_PROXY=0
# Strict mode: sh scripts/check-low-latency-host.sh exits non-zero on memory warnings.
RA2_MEMORY_STRICT=0
# If swap pressure remains high, try RESOLUTION=800x600 and WEBRTC_VIDEO_* below.

# Browser latency overlay and low-latency audio defaults (tuned for two containers).
LATENCY_OVERLAY_ENABLED=1
AUDIO_BUFFER_MIN_REMAIN=3
AUDIO_DRIFT_CHECK_INTERVAL_MS=2000
AUDIO_DRIFT_MAX_TOLERANCE=0.5
AUDIO_TARGET_LATENCY=1.0
AUDIO_MAX_PLAYBACK_RATE_DELTA=0.03
AUDIO_BITRATE=96000
AUDIO_WEBM_CLUSTER_MS=150
AUDIO_OPUS_FRAME_MS=20
AUDIO_QUEUE_BUFFERS=4

PLAYER1_HTTP_PORT=6081
PLAYER2_HTTP_PORT=6082

# WebRTC remote play (opt-in overlay: RA2_COMPOSE_WEBRTC=1).
# Synology: set RA2_COMPOSE_WEBRTC_HOST=1 to attach a macvlan LAN IP (fixes Docker UDP NAT).
# Also set NAS_LAN_INTERFACE (e.g. eth0) and PLAYER1_MACVLAN_IP to a free address on your subnet.
RA2_COMPOSE_WEBRTC_HOST=0
NAS_LAN_INTERFACE=eth0
NAS_LAN_SUBNET=192.168.0.0/24
NAS_LAN_GATEWAY=192.168.0.1
PLAYER1_MACVLAN_IP=192.168.0.250
PLAYER2_MACVLAN_IP=192.168.0.251
# Forward contiguous TCP ports 6081-6086 and UDP/TCP media range 62001-62040 on the router.
PLAYER1_WEBRTC_SIGNAL_PORT=6083
PLAYER2_WEBRTC_SIGNAL_PORT=6084
PLAYER1_WEBRTC_INPUT_PORT=6085
PLAYER2_WEBRTC_INPUT_PORT=6086
PLAYER1_WEBRTC_UDP_MIN=62001
PLAYER1_WEBRTC_UDP_MAX=62020
PLAYER1_WEBRTC_VIDEO_UDP_MIN=62001
PLAYER1_WEBRTC_VIDEO_UDP_MAX=62010
PLAYER1_WEBRTC_AUDIO_UDP_MIN=62011
PLAYER1_WEBRTC_AUDIO_UDP_MAX=62020
PLAYER2_WEBRTC_UDP_MIN=62021
PLAYER2_WEBRTC_UDP_MAX=62040
PLAYER2_WEBRTC_VIDEO_UDP_MIN=62021
PLAYER2_WEBRTC_VIDEO_UDP_MAX=62030
PLAYER2_WEBRTC_AUDIO_UDP_MIN=62031
PLAYER2_WEBRTC_AUDIO_UDP_MAX=62040
STUN_URL=stun:stun.l.google.com:19302
# Latency preset: stable (default), low, or experimental (H265; Safari untested).
WEBRTC_LATENCY_PRESET=stable
# Hardware H.264 is the target path for DS225+ WebRTC. If this fails, run
# scripts/check-transcode.sh and verify gst-inspect-1.0 vah264enc succeeds
# inside both player containers before falling back to software.
WEBRTC_VIDEO_CODEC=H264
WEBRTC_VIDEO_REQUIRE_HW=1
WEBRTC_VIDEO_WIDTH=1024
WEBRTC_VIDEO_HEIGHT=768
WEBRTC_VIDEO_FPS=20
WEBRTC_VIDEO_BITRATE=800000
WEBRTC_VIDEO_KEYFRAME_SECONDS=1
# Keep RTP payloads below common Docker/Wi-Fi fragmentation thresholds.
WEBRTC_VIDEO_RTP_MTU=700
WEBRTC_OFFER_WAIT_SECONDS=30
# Docker UDP media showed high packet loss on this DS225+; TCP ICE is steadier.
# Enable UDP test profile: RA2_COMPOSE_WEBRTC_UDP=1 (see compose.webrtc-udp.yaml).
WEBRTC_ICE_TCP=1
WEBRTC_ICE_UDP=0
RA2_COMPOSE_WEBRTC_UDP=0
# Input backend: xdotool (default for Xvfb), uinput, or auto (uinput if /dev/uinput works).
# Enable uinput device passthrough only after loading uinput.ko: RA2_COMPOSE_WEBRTC_UINPUT=1
WEBRTC_INPUT_BACKEND=xdotool
UINPUT_DEVICE=/dev/uinput
RA2_COMPOSE_WEBRTC_UINPUT=0
WEBRTC_AUDIO_BITRATE=96000
WEBRTC_AUDIO_FRAME_MS=10
WEBRTC_AUDIO_RATE=44100
# HTTPS remote.html needs WSS signaling/input; set to 0 only for plain-http LAN testing.
WEBRTC_SIGNAL_TLS=1
WEBRTC_INPUT_TLS=1

# HTTPS (recommended). noVNC 1.5+ needs a secure context for audio and crypto.
# 1) sh scripts/generate-tls-certs.sh
# 2) docker compose --env-file .env -f compose.yaml -f compose.https.yaml up -d
NAS_HOSTNAME=MediaServer2.local
NAS_LAN_IP=192.168.0.193
NAS_PUBLIC_HOSTNAME=peterjfrancoiii2.synology.me
# Override WebRTC ICE host candidates for DDNS remote play; leave empty for LAN-only.
WEBRTC_ICE_CANDIDATE_HOST=peterjfrancoiii2.synology.me
# TURN relay for browsers that cannot reach STUN (required for many remote networks).
# Uses ports 62011-62014 inside player-1 (same router range as WebRTC media).
WEBRTC_TURN_URLS=turn:peterjfrancoiii2.synology.me:62011?transport=udp,turn:peterjfrancoiii2.synology.me:62011?transport=tcp
WEBRTC_TURN_USERNAME=ra2turn
WEBRTC_TURN_PASSWORD=Ra2TurnRelay2026!
TLS_DIR=/volume2/Data/App_Development/ra2-lan-party/tls

# Hardware video-transcoding overlay values.
# Opt in with RA2_COMPOSE_TRANSCODE=1 after the base noVNC stack is stable.
# Check Synology IDs with:
#   stat -c '%g %n' /dev/dri/renderD128 /dev/dri/card0
# DS225+ (J4125 / Gemini Lake) commonly exposes renderD128 as group 937 (videodriver).
# J4125 VA-API encode works more reliably with the legacy i965 driver than iHD.
# Synology also ships a stripped i915 stack; enable host drivers with:
#   sudo sh scripts/enable-host-transcode.sh
DRI_DEVICE=/dev/dri
RENDER_GID=937
VIDEO_GID=44
LIBVA_DRIVER_NAME=i965
RA2_COMPOSE_TRANSCODE=0

# Browser-only ultra-light Arch streaming (GOLDEN MASTER — production path).
# Split protocol: WebRTC UDP video + WSS audio/control/input.
# See docs/GOLDEN_MASTER.md and docs/GOLDEN_MASTER_UDP_LAN.md
RA2_COMPOSE_ULTRA=1
WINE_VARIANT=amd64
WINE_ARCH=win32
WINE_ENABLE_MULTILIB=1
# Game CPU affinity is derived from PLAYER_ID (player 1 -> core 0, player 2 -> core 1).
# Dedicated CPUs for the capture/encode helper, kept off the pinned game cores.
# On the 4-core J4125, cores 0 and 1 run the two games; 2 and 3 run the encoders.
ULTRA_STREAM_CPUSET=2,3
# GPU convert/scale via vapostproc (measured ~40% helper CPU cut on J4125).
# Set to 0 to fall back to the CPU videoconvert pipeline without a rebuild.
ULTRA_VIDEO_GPU_SCALE=1
ULTRA_VIDEO_CODEC=H265_10
# Optional: lock browser sessions to H.264 during mission play (prevents HEVC helper restarts).
# Leave unset to allow H.265 8-bit / 10-bit in the transport menu.
#ULTRA_STREAM_CODEC_LOCK=H264
ULTRA_VIDEO_REQUIRE_HW=1
# Stream encode size follows RESOLUTION (the Xvfb display) when unset.
#ULTRA_VIDEO_WIDTH=1024
#ULTRA_VIDEO_HEIGHT=768
# Xvfb framebuffer depth (16 = 65536 colors, matches classic RA2 high-color mode).
# Use 24 if you need the 10-bit HEVC transport path (encode is P010 Main10).
RA2_DISPLAY_DEPTH=16
ULTRA_VIDEO_FPS=24
# In-game render cap (stream encode still uses ULTRA_VIDEO_FPS).
ULTRA_GAME_MAX_FPS=24
ULTRA_GAME_MAX_TICKS=0
# Pause X11 capture while gamemd loads the mission map (avoids map-load freezes).
ULTRA_MAP_LOAD_CAPTURE_PAUSE_S=60
ULTRA_VIDEO_BITRATE=2000000
ULTRA_INPUT_MOVE_HZ=60
ULTRA_VIDEO_KEYFRAME_SECONDS=1
ULTRA_VIDEO_DIAGNOSTICS=1
# HEVC hardware encode is verified on the J4125 (Main + Main10 entrypoints);
# this exposes the H.265 8-bit/10-bit options in the browser. H.264 stays the
# default codec until H.265 has longer gameplay coverage.
ULTRA_H265_TEST_ENABLED=1
# Optional targeted GStreamer traces while debugging H.265/QSV.
# Example: ULTRA_GST_DEBUG=qsv*:6,msdk*:6,va*:5,vah265enc:6,vaapih265enc:6
ULTRA_GST_DEBUG=
ULTRA_GATEWAY_TLS=1
ULTRA_AUDIO_CODEC=opus
ULTRA_AUDIO_BITRATE=64000
ULTRA_AUDIO_FRAME_MS=20
# Opus uses 48 kHz end-to-end (native Opus rate). Use 44100 only with PCM encoder.
ULTRA_AUDIO_RATE=48000
ULTRA_AUDIO_TRANSPORT_RATE=48000

# Split-protocol video: UDP media ports (62001-62010 / 62021-62030) + WSS for control/audio.
# Forward those UDP ranges on the router for remote play. See compose.ultra-udp.yaml.
RA2_COMPOSE_ULTRA_UDP=1
# Bypass Synology Docker bridge UDP masquerading for player 1 WebRTC (see Research/).
RA2_COMPOSE_ULTRA_UDP_HOST=1
ULTRA_VIDEO_UDP=1

# Moonlight primary path (side-by-side experiments — do not replace Cloud_Gaming_Player1/2 yet).
# Profile 1: Wolf (primary) or Sunshine (secondary). Profile 2: Selkies browser stack.
RA2_COMPOSE_MOONLIGHT=0
RA2_COMPOSE_WOLF=0
RA2_COMPOSE_SELKIES=0
RA2_COMPOSE_MOONLIGHT_UINPUT=0
INTEL_DEBUG=norbc
MESA_LOADER_DRIVER_OVERRIDE=zink
SELKIES_IMAGE=lscr.io/linuxserver/webtop:latest
SELKIES_HTTPS_PORT=6101
SELKIES_HTTP_PORT=6100
SELKIES_MAX_RES=1280x720
SELKIES_MAX_RESOLUTION=1280x720
SELKIES_MANUAL_WIDTH=1280
SELKIES_MANUAL_HEIGHT=720
SELKIES_FRAMERATE=24
SELKIES_H264_CRF=25
SELKIES_PASSWORD=change-me
SUNSHINE_CONFIG_DIR=./data/sunshine-experiment/config
WOLF_CONFIG_DIR=./data/wolf-experiment/config
SUNSHINE_USER=ra2admin
SUNSHINE_PASSWORD=change-me

# Tailscale for secure remote Moonlight (do not expose GameStream ports to internet).
RA2_COMPOSE_TAILSCALE=0
TAILSCALE_AUTHKEY=
TAILSCALE_HOSTNAME=ra2-nas
TAILSCALE_STATE_DIR=./data/tailscale/state
NAS_LAN_INTERFACE=eth0

# Docker container names (shown in `docker ps` and used by `docker exec`).
PLAYER1_CONTAINER=Cloud_Gaming_Player1
PLAYER2_CONTAINER=Cloud_Gaming_Player2

# Per-player identity (only these differ between player 1 and player 2):
PLAYER1_SERIAL=11112222333344445555
PLAYER2_SERIAL=55554444333322221111
# Shared container secret (legacy PLAYER1_VNC_PASSWORD / PLAYER2_VNC_PASSWORD still accepted).
VNC_PASSWORD=change-me
