{
  "ra2": {
    "title": "Red Alert 2 + Yuri's Revenge",
    "assetsEnv": "ASSETS_DIR",
    "assetsPath": "/home/commander/game_assets",
    "gameExe": "RA2MD.exe",
    "supervisedProcess": "gamemd.exe",
    "wineArgs": ["-SPEEDCONTROL"],
    "driveCLink": "RA2",
    "dllOverrides": "mscoree=d;mshtml=d;ddraw=n,b;wsock32=n,b",
    "syncTransport": true,
    "ensureIniLinks": true,
    "gameWidth": 1024,
    "gameHeight": 768,
    "preflight": ["RA2MD.exe", "ddraw.dll", "ddraw.ini", "wsock32.dll"]
  },
  "aoe2": {
    "title": "Age of Empires II (1999)",
    "assetsEnv": "AOE2_ASSETS_DIR",
    "assetsPath": "/home/commander/aoe2_assets",
    "gameExe": "EMPIRES2.EXE",
    "supervisedProcess": "EMPIRES2.EXE",
    "wineExePath": "C:\\AOE2\\EMPIRES2.EXE",
    "wineArgs": ["NoStartup", "800"],
    "wineD3dConfig": "renderer=gdi",
    "driveCLink": "AOE2",
    "dllOverrides": "mscoree=d;mshtml=d;comctl32=b;ddraw=n,b",
    "useCncDdraw": true,
    "writableWorkDir": true,
    "ddrawIni": "/opt/ra2/config/aoe2-ddraw.ini",
    "languageDir": "/opt/ra2/config/aoe2-language",
    "gameLocale": "C",
    "syncTransport": false,
    "ensureIniLinks": false,
    "gameWidth": 800,
    "gameHeight": 600,
    "preflight": ["EMPIRES2.EXE"]
  },
  "starcraft": {
    "title": "StarCraft + Brood War",
    "assetsEnv": "SC_ASSETS_DIR",
    "assetsPath": "/home/commander/sc_assets",
    "gameExe": "StarCraft.exe",
    "supervisedProcess": "StarCraft.exe",
    "wineExePath": "C:\\SC\\StarCraft.exe",
    "driveCLink": "SC",
    "dllOverrides": "mscoree=d;mshtml=d;comctl32=b;ddraw=n,b",
    "writableWorkDir": true,
    "ddrawIni": "/opt/ra2/config/starcraft-ddraw.ini",
    "gameWidth": 640,
    "gameHeight": 480,
    "gameLocale": "en_US.UTF-8",
    "syncTransport": false,
    "ensureIniLinks": false,
    "preflight": ["StarCraft.exe", "StarCraft.mpq", "BroodWar.mpq", "storm.dll"]
  }
}
