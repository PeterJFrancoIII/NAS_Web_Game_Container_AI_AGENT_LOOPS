# Minimal PulseAudio graph for RA2 browser audio.

.fail
load-module module-native-protocol-unix auth-anonymous=1 socket=/tmp/pulse/native

load-module module-null-sink sink_name=game sink_properties=device.description=RA2_Game_Audio rate=48000
set-default-sink game
set-default-source game.monitor

load-module module-simple-protocol-tcp listen=127.0.0.1 port=4711 format=s16le channels=2 rate=48000 record=true playback=false
